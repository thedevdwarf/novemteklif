# Listener portları
PORT_INTERNAL=7878
PORT_PUBLIC=7879
BIND_ADDR=127.0.0.1

# MongoDB
MONGO_URL=mongodb://127.0.0.1:27017
MONGO_DB=teklify

# PDF çıktı dizini (WSL içi)
OUT_DIR=/home/Teklifler

# Public preview için kullanılacak base URL
# (cloudflared tunnel hangi domaine bağlıysa)
PUBLIC_BASE_URL=https://teklif.novem.com.tr

# Preview token TTL (gün)
PREVIEW_TTL_DAYS=7

# Şirket sabit bilgileri (kapakta ve footer'da)
COMPANY_NAME=Novem Yazılım ve Danışmanlık Tic. Ltd. Şti.
COMPANY_ADDRESS=Atatürk Mh. Komsan Üstü Yolu Cd. Residence Quality No:4/28 Küçükçekmece / İstanbul
COMPANY_TAX=Halkalı V.D. · 632 155 9162

# Teklif numara öneki
PROPOSAL_PREFIX=NVM

# Telegram bot (send_message_to_member tool için).
# openclaw config'inde zaten kayıtlı bot token'ı buraya da koy
# (aynı bot — outgoing sendMessage için ayrıca polling yapmıyor).
TELEGRAM_BOT_TOKEN=
